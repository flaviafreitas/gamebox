# Supabase (seguras de expor — embutidas no bundle do app)
EXPO_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# --------------------------------------------------------------------------
# As credenciais da Twitch/IGDB NÃO ficam aqui. Elas são secrets da Edge
# Function do Supabase (server-side), configuradas com:
#   supabase secrets set TWITCH_CLIENT_ID=... TWITCH_CLIENT_SECRET=...
# --------------------------------------------------------------------------
